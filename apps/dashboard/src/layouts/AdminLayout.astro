---
import { ClientRouter, fade } from 'astro:transitions'
import NavPlanSync from '../components/NavPlanSync'
import CheckoutSuccessModal from '../components/CheckoutSuccessModal'
import SiteGuard from '../components/SiteGuard'
import UsageNudgeBanner from '../components/UsageNudgeBanner'

interface Props {
  title: string
  page:
    | 'comments'
    | 'users'
    | 'sites'
    | 'preview'
    | 'import'
    | 'analytics'
    | 'moderation-rules'
    | 'billing'
    | 'help'
    | 'account'
}

const { title, page } = Astro.props
const isSelfHosted = import.meta.env.PUBLIC_BUILD_TARGET === 'selfhosted'
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Quipthread Admin</title>
    <link rel="icon" href="/dashboard/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/dashboard/manifest.webmanifest" />
    <meta name="theme-color" content="#1A1A1A" />
    <link rel="apple-touch-icon" href="/dashboard/icon-192.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600&family=Lora:wght@600&family=Syne:wght@700&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      const p = localStorage.getItem('qt-plan')
      if (p) document.documentElement.dataset.plan = p
    </script>
    <ClientRouter />
  </head>
  <body>
    <div class="shell">
      <div class="mobile-header" id="mobile-header" transition:persist="mobile-header">
        <button class="hamburger" id="nav-hamburger" aria-label="Open navigation">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M3 5h14M3 10h14M3 15h14" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
          </svg>
        </button>
        <span class="mobile-brand">Quipthread</span>
      </div>
      <div class="sidebar-overlay" id="sidebar-overlay"></div>
      <aside class="sidebar" transition:persist="sidebar">
        <div class="brand">
          <span class="brand-name">Quipthread</span>
          <span class="brand-tag">Admin</span>
        </div>
        <nav class="nav-links">
          <a href="/dashboard/comments" class={page === 'comments' ? 'active' : ''}>
            Comments
          </a>
          <a href="/dashboard/users" class={page === 'users' ? 'active' : ''}>
            Users
          </a>
          <a href="/dashboard/sites" class={page === 'sites' ? 'active' : ''}>
            Sites
          </a>
          <a href="/dashboard/preview" class={page === 'preview' ? 'active' : ''}>
            Preview
          </a>
          <a href="/dashboard/import" class={page === 'import' ? 'active' : ''}>
            Import
          </a>

          <div class="nav-divider"></div>

          {!isSelfHosted && (
          <a href="/dashboard/analytics" class={page === 'analytics' ? 'active' : ''}>
            Analytics
            <span class="nav-badge nav-badge-starter">Starter</span>
          </a>
          )}
          <a href="/dashboard/moderation-rules" class={page === 'moderation-rules' ? 'active' : ''}>
            Mod Rules
            {!isSelfHosted && <span class="nav-badge nav-badge-pro">Pro</span>}
          </a>

          <div class="nav-divider"></div>

          {!isSelfHosted && (
          <a href="/dashboard/billing" class={page === 'billing' ? 'active' : ''}>
            Billing
          </a>
          )}
          <a href="/dashboard/account" class={page === 'account' ? 'active' : ''}>
            Account
          </a>
          <a href="/dashboard/help" class={page === 'help' ? 'active' : ''}>
            Help
          </a>
        </nav>
        <div class="sidebar-footer">
          <button class="nav-logout" id="nav-logout">Sign out</button>
        </div>
      </aside>
      <main class="main" transition:animate={fade({ duration: '0.25s' })}>
        {!isSelfHosted && <UsageNudgeBanner client:load />}
        <slot />
      </main>
    </div>
    {!isSelfHosted && <NavPlanSync client:load />}
    {!isSelfHosted && <CheckoutSuccessModal client:load />}
    {!isSelfHosted && <SiteGuard client:load />}
    <script>
      // Idle session timeout — runs once as a module script, persists across navigations
      const IDLE_MS = 45 * 60 * 1000
      let idleTimer: ReturnType<typeof setTimeout>
      function resetIdle() {
        clearTimeout(idleTimer)
        idleTimer = setTimeout(async () => {
          await fetch('/auth/logout', { method: 'POST', credentials: 'include' }).catch(() => {})
          window.location.href = '/login'
        }, IDLE_MS)
      }
      ;['mousedown', 'keydown', 'scroll', 'touchstart'].forEach(evt => {
        document.addEventListener(evt, resetIdle, { passive: true, capture: true })
      })
      document.addEventListener('astro:page-load', resetIdle)
      resetIdle()

      document.addEventListener('astro:page-load', () => {
        const btn = document.getElementById('nav-logout')
        if (btn) btn.addEventListener('click', async () => {
          await fetch('/auth/logout', { method: 'POST', credentials: 'include' }).catch(() => {})
          window.location.href = '/login'
        })

        const hamburger = document.getElementById('nav-hamburger')
        const overlay = document.getElementById('sidebar-overlay')
        const shell = document.querySelector('.shell')
        if (hamburger) {
          hamburger.addEventListener('click', () => shell?.classList.toggle('sidebar-open'))
        }
        if (overlay) {
          overlay.addEventListener('click', () => shell?.classList.remove('sidebar-open'))
        }
        document.querySelectorAll('.sidebar .nav-links a').forEach(a => {
          a.addEventListener('click', () => shell?.classList.remove('sidebar-open'))
        })

        // Update active nav link based on current pathname (sidebar is transition:persist-ed,
        // so server-rendered active class is stale after client-side navigation)
        const path = window.location.pathname
        document.querySelectorAll('.sidebar .nav-links a').forEach(a => {
          const href = a.getAttribute('href') ?? ''
          a.classList.toggle('active', path === href || path.startsWith(href + '/'))
        })
      })
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/shared.css';

  *, *::before, *::after { box-sizing: border-box; }

  :root {
    /* Brand palette */
    --ink:          #0F0F0F;
    --ink-mid:      #1A1A1A;
    --paper:        #F7F4EF;
    --surface:      #EEEBE4;
    --border:       #D9D4CB;
    --muted:        #7A7570;
    --text:         #1A1714;

    --amber:        #C06020;
    --amber-hi:     #E07F32;
    --amber-bg:     #F5E0CE;
    --amber-border: #DDB08C;

    --green-text:   #166534;
    --green-bg:     #DCFCE7;
    --green-border: #86EFAC;

    --red-text:     #991B1B;
    --red-bg:       #FEE2E2;
    --red-border:   #FCA5A5;

    --blue-text:    #1E40AF;
    --blue-bg:      #EFF6FF;
    --blue-border:  #93C5FD;

    --purple-text:  #5B21B6;
    --purple-bg:    #EDE9FE;

    --bg:       #F7F4EF;   /* same as --paper; used for body background */
    --card-bg:  #FFFFFF;   /* cards, tables, inputs, buttons */

    /* Typography */
    --f-display: 'Lora', Georgia, serif;
    --f-ui:      'DM Sans', system-ui, sans-serif;
    --f-mono:    'ui-monospace', 'SF Mono', 'Fira Code', monospace;
  }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    font-family: var(--f-ui);
    font-size: 15px;
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
  }

  .shell {
    display: flex;
    min-height: 100vh;
  }

  /* ── Sidebar ─────────────────────────────────────────── */

  .sidebar {
    width: 216px;
    flex-shrink: 0;
    background: var(--ink);
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding: 1.75rem 1rem;
    position: sticky;
    top: 0;
    height: 100vh;
    overflow-y: auto;
  }

  .brand {
    padding: 0.25rem 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .brand-name {
    font-family: 'Syne', system-ui, sans-serif;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--paper);
    line-height: 1.2;
  }

  .brand-tag {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--amber-hi);
  }

  .nav-links {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .nav-links a {
    display: flex;
    align-items: center;
    padding: 0.5rem 0.75rem;
    padding-left: calc(0.75rem - 2px);
    border-left: 2px solid transparent;
    border-radius: 4px;
    text-decoration: none;
    color: rgba(247, 244, 239, 0.45);
    font-size: 0.9375rem;
    font-weight: 500;
    transition: color 0.12s, background 0.12s, border-color 0.12s;
  }

  .nav-links a:hover {
    color: rgba(247, 244, 239, 0.82);
    background: rgba(255, 255, 255, 0.05);
  }

  .nav-links a.active {
    color: var(--paper);
    background: rgba(255, 255, 255, 0.07);
    border-left-color: var(--amber-hi);
  }

  /* ── Main ────────────────────────────────────────────── */

  .main {
    flex: 1;
    min-width: 0;
    padding: 2.5rem 3rem;
    max-width: 1180px;
  }

  button { font-family: var(--f-ui); }

  /* ── Moderation queue ─────────────────────────────────── */

  .queue-tabs {
    display: flex;
    gap: 0.25rem;
    margin-bottom: 0.75rem;
  }

  .queue-tab {
    padding: 0.3125rem 0.875rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: transparent;
    color: var(--muted);
    font-size: 0.8125rem;
    font-family: var(--f-ui);
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
  }

  .queue-tab:hover {
    color: var(--text);
    border-color: var(--muted);
  }

  .queue-tab.active {
    color: var(--blue-text);
    border-color: var(--blue-border);
    font-weight: 500;
  }

  .flag-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.125rem;
    height: 1.125rem;
    padding: 0 0.25rem;
    margin-left: 0.375rem;
    border-radius: 999px;
    background: var(--red-bg, #fff0f0);
    color: var(--red-text, #c0392b);
    font-size: 0.6875rem;
    font-weight: 600;
    line-height: 1;
    vertical-align: middle;
  }

  .queue-toolbar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.875rem;
  }

  .bulk-bar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 0.875rem;
    margin-bottom: 0.75rem;
    background: var(--blue-bg);
    border: 1px solid var(--blue-border);
    border-radius: 7px;
    font-size: 0.875rem;
    animation: slide-in 0.15s ease;
  }

  @keyframes slide-in {
    from { opacity: 0; transform: translateY(-5px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* CSS subgrid layout for the queue list */
  .mq-grid {
    display: grid;
    grid-template-columns: 40px minmax(100px, 150px) 1fr minmax(110px, 165px) 80px auto;
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    background: var(--card-bg);
  }

  .mq-header { display: contents; }

  .mq-header > div {
    padding: 0.5rem 0.875rem;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--muted);
    display: flex;
    align-items: center;
  }

  .mq-row {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: subgrid;
  }

  .mq-row.selected > .mq-cell {
    background: #FDFAF6;
  }

  .mq-cell {
    padding: 0.8125rem 0.875rem;
    border-bottom: 1px solid var(--surface);
    display: flex;
    align-items: center;
    font-size: 0.875rem;
    min-width: 0;
  }

  .mq-grid > .mq-row:last-child > .mq-cell {
    border-bottom: none;
  }

  /* Accordion panel — grid-template-rows transition */
  .mq-expand {
    grid-column: 1 / -1;
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 230ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .mq-expand.open {
    grid-template-rows: 1fr;
  }

  .mq-expand-inner {
    overflow: hidden;
  }

  .mq-expand-content {
    padding: 1.375rem 1.5rem;
    background: var(--bg);
    border-top: 1px solid var(--border);
  }

  /* Expand toggle button */
  .expand-toggle {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
    border-radius: 4px;
    border: none;
    background: none;
    cursor: pointer;
    color: var(--muted);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-left: 0.375rem;
    transition: color 0.12s, background 0.12s;
  }

  .expand-toggle:hover {
    color: var(--text);
    background: var(--surface);
  }

  .expand-toggle svg {
    width: 13px;
    height: 13px;
    transition: transform 230ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .expand-toggle.open svg {
    transform: rotate(90deg);
  }

  /* Expanded content styles */
  .comment-prose {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--text);
  }

  .comment-prose > *:first-child { margin-top: 0; }
  .comment-prose > *:last-child  { margin-bottom: 0; }
  .comment-prose p { margin: 0 0 0.75em; }
  .comment-prose strong { font-weight: 600; }
  .comment-prose em { font-style: italic; }

  .comment-prose a {
    color: var(--amber);
    text-decoration: underline;
    text-decoration-color: var(--amber-border);
  }

  .comment-prose code {
    font-family: var(--f-mono);
    font-size: 0.875em;
    background: var(--surface);
    padding: 0.1em 0.35em;
    border-radius: 3px;
  }

  .comment-prose pre {
    background: var(--ink);
    color: var(--paper);
    padding: 1rem;
    border-radius: 6px;
    overflow-x: auto;
    font-size: 0.875em;
    font-family: var(--f-mono);
  }

  .expand-label {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.5rem;
  }

  .expand-actions {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.875rem;
  }

  .expand-hint {
    font-size: 0.8125rem;
    color: var(--muted);
    margin-top: 0.375rem;
  }

  .sidebar-footer {
    margin-top: auto;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.07);
  }

  .nav-logout {
    width: 100%;
    background: none;
    border: none;
    padding: 0.5rem 0.75rem;
    border-radius: 4px;
    text-align: left;
    font-family: var(--f-ui);
    font-size: 0.9375rem;
    font-weight: 500;
    color: rgba(247, 244, 239, 0.45);
    cursor: pointer;
    transition: color 0.12s, background 0.12s;
  }

  .nav-logout:hover {
    color: rgba(247, 244, 239, 0.82);
    background: rgba(255, 255, 255, 0.05);
  }

  .nav-divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.07);
    margin: 0.375rem 0.5rem;
  }

  .nav-badge {
    margin-left: auto;
    font-size: 0.5625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.1em 0.45em;
    border-radius: 3px;
    background: rgba(224, 127, 50, 0.18);
    color: var(--amber-hi);
    flex-shrink: 0;
  }

  /* Progress bar for billing/usage meters */
  .usage-bar {
    height: 6px;
    background: var(--surface);
    border-radius: 9999px;
    overflow: hidden;
    margin-top: 0.375rem;
  }

  .usage-bar-fill {
    height: 100%;
    background: var(--amber);
    border-radius: 9999px;
    transition: width 0.4s ease;
  }

  .usage-bar-fill.danger {
    background: var(--red-text);
  }

  /* Hide nav plan badges once the user's plan meets the threshold */
  html[data-plan="starter"] .nav-badge-starter,
  html[data-plan="pro"] .nav-badge-starter,
  html[data-plan="pro"] .nav-badge-pro,
  html[data-plan="business"] .nav-badge-starter,
  html[data-plan="business"] .nav-badge-pro,
  html[data-plan="business"] .nav-badge-business {
    display: none;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --bg:           #111110;
      --card-bg:      #1A1918;
      --surface:      #1C1B19;
      --border:       #2E2C29;
      --muted:        #8A8480;
      --text:         #E8E3DC;

      --amber:        #E07F32;
      --amber-hi:     #F09550;
      --amber-bg:     rgba(224, 127, 50, 0.15);
      --amber-border: rgba(224, 127, 50, 0.35);

      --green-text:   #4ADE80;
      --green-bg:     rgba(20, 83, 45, 0.35);
      --green-border: rgba(134, 239, 172, 0.25);

      --red-text:     #FCA5A5;
      --red-bg:       rgba(127, 29, 29, 0.4);
      --red-border:   rgba(252, 165, 165, 0.25);

      --blue-text:    #93C5FD;
      --blue-bg:      rgba(30, 64, 175, 0.35);
      --blue-border:  rgba(147, 197, 253, 0.25);

      --purple-text:  #C4B5FD;
      --purple-bg:    rgba(91, 33, 182, 0.35);
    }

    /* selected moderation queue row */
    .mq-row.selected > .mq-cell {
      background: #1E1D1B;
    }
  }

  /* ── Layout helpers (used by Preact components) ───────── */

  .mq-scroll {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .preview-layout {
    display: grid;
    grid-template-columns: 360px 1fr;
    gap: 1.5rem;
    align-items: start;
  }


  .preview-iframe {
    width: 100%;
    height: 520px;
    border: none;
    display: block;
  }

  /* ── Mobile header ────────────────────────────────────── */

  .mobile-header {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 56px;
    background: var(--ink);
    z-index: 100;
    align-items: center;
    gap: 0.75rem;
    padding: 0 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
  }

  .hamburger {
    background: none;
    border: none;
    cursor: pointer;
    color: rgba(247, 244, 239, 0.65);
    padding: 0.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
    flex-shrink: 0;
  }

  .hamburger:hover {
    color: var(--paper);
    background: rgba(255, 255, 255, 0.07);
  }

  .mobile-brand {
    font-family: 'Syne', system-ui, sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: var(--paper);
  }

  .sidebar-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
    z-index: 150;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s;
  }

  /* ── Responsive ───────────────────────────────────────── */

  @media (max-width: 768px) {
    .mobile-header {
      display: flex;
    }

    .sidebar-overlay {
      display: block;
    }

    .shell.sidebar-open .sidebar-overlay {
      opacity: 1;
      pointer-events: auto;
    }

    .sidebar {
      position: fixed;
      top: 0;
      left: 0;
      height: 100vh;
      z-index: 200;
      transform: translateX(-100%);
      transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .shell.sidebar-open .sidebar {
      transform: translateX(0);
    }

    .main {
      padding: 1.25rem 1rem;
      padding-top: calc(56px + 1.25rem);
    }

    .queue-toolbar {
      flex-wrap: wrap;
    }

    .bulk-bar {
      flex-wrap: wrap;
    }

    .preview-layout {
      grid-template-columns: minmax(0, 1fr);
    }

    .preview-layout > * {
      min-width: 0;
    }

    .preview-iframe {
      height: 380px;
    }

    .mq-grid {
      min-width: 580px;
    }

    /* ── Touch targets ──────────────────────────────────── */

    /* Nav links — 44px minimum tap height */
    .nav-links a {
      padding: 0.75rem 0.875rem;
      padding-left: calc(0.875rem - 2px);
      min-height: 44px;
      font-size: 1rem;
    }

    .nav-logout {
      min-height: 44px;
      font-size: 1rem;
    }

    /* Hamburger — full 44×44 tap zone */
    .hamburger {
      width: 44px;
      height: 44px;
    }

    /* ── Section headings in panels ─────────────────────── */

    h2 {
      font-size: 0.9375rem;
    }

    /* ── Bulk bar spacing ───────────────────────────────── */

    .bulk-bar {
      gap: 0.5rem;
      padding: 0.75rem;
    }

    .bulk-bar .btn {
      flex: 1;
      justify-content: center;
    }

    /* ── Analytics header controls ──────────────────────── */

    .analytics-controls {
      flex-wrap: wrap;
    }

    /* ── Embed code tabs ────────────────────────────────── */

    .embed-tab-btn {
      min-height: 44px;
    }

    /* ── Preview layout tighter on mobile ───────────────── */

    .preview-layout {
      gap: 1rem;
    }

  }

  @media (max-width: 600px) {
    /* Preview page section cards: tighter padding on small screens */
    .preview-section {
      padding: 1rem !important;
    }

    /* Analytics controls: full width row on mobile */
    .analytics-controls {
      width: 100%;
    }

    /* ── ModerationQueue card layout ─────────────────────── */

