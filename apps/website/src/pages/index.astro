---
import '@knadh/oat/oat.min.css'
import Layout from '../layouts/Layout.astro'
import FeatureCard from '../components/FeatureCard.astro'
import PricingCard from '../components/PricingCard.astro'
import HeroWidget from '../components/HeroWidget.astro'

const backendUrl = import.meta.env.PUBLIC_BACKEND_URL || 'http://localhost:8080'
const loginUrl = `${backendUrl}/login`
const signupUrl = `${backendUrl}/signup`
const year = new Date().getFullYear()

const monthlyPlans = [
  {
    tier: 'Hobby',
    plan: 'hobby',
    price: 'Free',
    description: 'Personal blogs and portfolio sites.',
    features: [
      { text: '1 site' },
      { text: '1,000 comments / month' },
      { text: 'All auth providers' },
      { text: 'Comment approval flows' },
      { text: 'Email notifications' },
      { text: 'Quick-approve via email' },
      { text: 'Moderation dashboard', muted: true },
      { text: 'Comment export', muted: true },
      { text: 'Analytics', muted: true },
    ],
    ctaText: 'Get started',
    ctaHref: signupUrl,
  },
  {
    tier: 'Starter',
    plan: 'starter',
    price: '$9',
    period: '/ month',
    description: 'Indie developers and content creators.',
    features: [
      { text: '5 sites' },
      { text: '10,000 comments / month' },
      { text: 'All Hobby features included' },
      { text: 'Moderation dashboard' },
      { text: 'Comment export (JSON, CSV)' },
      { text: 'Import (Disqus, WordPress, Remark42)' },
      { text: 'Basic analytics' },
      { text: 'Email support (48h)' },
      { text: 'Moderation rules engine', muted: true },
    ],
    ctaText: 'Start free trial',
    ctaHref: signupUrl,
  },
  {
    tier: 'Pro',
    plan: 'pro',
    price: '$24',
    period: '/ month',
    description: 'Professional developers and small teams.',
    features: [
      { text: '20 sites' },
      { text: '50,000 comments / month' },
      { text: 'All Starter features included' },
      { text: 'Moderation rules engine' },
      { text: 'Advanced analytics' },
      { text: 'Notification channels (Slack, Discord, Telegram, webhooks)' },
      { text: 'Priority support (24h)' },
    ],
    ctaText: 'Start free trial',
    ctaHref: signupUrl,
    ctaPrimary: true,
    featured: true,
  },
  {
    tier: 'Business',
    plan: 'business',
    price: '$79',
    period: '/ month',
    description: 'Agencies and platforms embedding comments into products.',
    features: [
      { text: 'Unlimited sites' },
      { text: '250,000 comments / month' },
      { text: 'All Pro features included' },
      { text: 'Dedicated DB per site' },
      { text: 'Dedicated support (4h SLA)' },
    ],
    ctaText: 'Start free trial',
    ctaHref: signupUrl,
  },
]

const annualPlans = [
  {
    tier: 'Hobby',
    plan: 'hobby',
    price: 'Free',
    description: 'Personal blogs and portfolio sites.',
    billingNote: 'Always free',
    features: monthlyPlans[0].features,
    ctaText: 'Get started',
    ctaHref: signupUrl,
  },
  {
    tier: 'Starter',
    plan: 'starter',
    price: '$7.50',
    period: '/ month',
    description: 'Indie developers and content creators.',
    billingNote: '$90 / year — 2 months free',
    features: monthlyPlans[1].features,
    ctaText: 'Start free trial',
    ctaHref: signupUrl,
  },
  {
    tier: 'Pro',
    plan: 'pro',
    price: '$19',
    period: '/ month',
    description: 'Professional developers and small teams.',
    billingNote: '$228 / year — 2 months free',
    features: monthlyPlans[2].features,
    ctaText: 'Start free trial',
    ctaHref: signupUrl,
    ctaPrimary: true,
    featured: true,
  },
  {
    tier: 'Business',
    plan: 'business',
    price: '$62.50',
    period: '/ month',
    description: 'Agencies and platforms embedding comments into products.',
    billingNote: '$750 / year',
    features: monthlyPlans[3].features,
    ctaText: 'Start free trial',
    ctaHref: signupUrl,
  },
]
---

<Layout loginUrl={loginUrl} year={year}>

  <!-- ── Hero ─────────────────────────────────────── -->
  <section class="hero">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="container">
      <div class="hero-content">
        <div class="hero-text">
          <p class="hero-eyebrow">
            <span class="badge outline">Open core</span>
            <span class="badge outline">Managed platform</span>
          </p>
          <h1>The comment system your readers will <em>actually use.</em></h1>
          <p class="subhead">
            Start accepting comments in minutes — no server setup, zero maintenance.
            No ads. No tracking. Your data, always exportable.
          </p>
          <div class="hero-actions">
            <a href={signupUrl} class="button large">Start for free</a>
            <a href="/docs/" class="button outline large">Read the docs</a>
          </div>
        </div>
        <div class="hero-visual">
          <HeroWidget />
        </div>
      </div>
    </div>
  </section>

  <!-- ── Features ──────────────────────────────────── -->
  <section class="section features">
    <div class="container">
      <p class="section-eyebrow">Why Quipthread</p>
      <div class="row">
        <FeatureCard title="Open Core" description="The comment engine, embed widget, and admin dashboard are fully open source (AGPL). Inspect the code, fork it, self-host it. No vendor lock-in.">
          <svg slot="icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
          </svg>
        </FeatureCard>
        <FeatureCard title="Your Data" description="No ad targeting. No data brokering. Comments belong to you — export everything as JSON or CSV at any time.">
          <svg slot="icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
        </FeatureCard>
        <FeatureCard title="Rich Comments" description="Markdown, threading, GitHub/Google/email auth, and email notifications. Everything readers need, nothing they don't.">
          <svg slot="icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
          </svg>
        </FeatureCard>
        <FeatureCard title="Spam Protection" description="Rate limiting, heuristic content analysis, Cloudflare Turnstile support, and a keyword blocklist keep your comments clean without moderator effort.">
          <svg slot="icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 4a1 1 0 0 1 1-1h16a1 1 0 0 1 .78 1.63L14 12.41V19a1 1 0 0 1-.55.89l-4 2A1 1 0 0 1 8 21v-8.59L3.22 5.63A1 1 0 0 1 3 5V4z"/>
          </svg>
        </FeatureCard>
      </div>
    </div>
  </section>

  <!-- ── How It Works ──────────────────────────────── -->
  <section class="section how-it-works">
    <div class="container">
      <p class="section-eyebrow">How it works</p>
      <h2>Up and running in three steps</h2>
      <div class="steps">
        <div class="step">
          <div class="step-num">1</div>
          <div class="step-body">
            <h4>Sign up and get your Site ID</h4>
            <p>Create an account and get a Site ID in under two minutes — no server required. Prefer to run your own infrastructure? Self-hosters deploy the Go binary with SQLite included.</p>
          </div>
        </div>
        <div class="step-connector"></div>
        <div class="step">
          <div class="step-num">2</div>
          <div class="step-body">
            <h4>Drop in the script tag</h4>
            <p>Paste one line into your site wherever you want comments. Loads asynchronously — zero layout shift, works with any framework or static site generator.</p>
          </div>
        </div>
        <div class="step-connector"></div>
        <div class="step">
          <div class="step-num">3</div>
          <div class="step-body">
            <h4>Moderate from your dashboard</h4>
            <p>Readers comment; you approve or reject from the admin dashboard. Pending comments notify you by email with a one-click approve link.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Pricing ────────────────────────────────────── -->
  <section class="section pricing" id="pricing">
    <div class="container">
      <p class="section-eyebrow">Pricing</p>
      <h2>Simple, transparent pricing</h2>
      <p class="section-sub">
        Self-host for free, forever. Or skip the ops work and use the managed platform.
        14-day free trial on Pro — no credit card required.
      </p>

      <ot-tabs class="pricing-tabs">
        <div role="tablist">
          <button role="tab">Monthly</button>
          <button role="tab">Annual <span class="badge success tab-badge">Save ~17%</span></button>
        </div>

        <!-- Monthly -->
        <div role="tabpanel" class="monthly-panel">
          <div class="pricing-grid">
            {monthlyPlans.map((plan) => (
              <PricingCard {...plan} />
            ))}
          </div>
        </div>

        <!-- Annual -->
        <div role="tabpanel" class="annual-panel">
          <div class="pricing-grid">
            {annualPlans.map((plan) => (
              <PricingCard {...plan} />
            ))}
          </div>
        </div>
      </ot-tabs>

      <article class="card enterprise-card">
        <div class="enterprise-content">
          <div>
            <strong>Enterprise</strong>
            <p>Volume limits, custom data residency, contracts, dedicated onboarding, and a dedicated support channel.</p>
          </div>
          <a href="mailto:hello@quipthread.com" class="button outline">Contact us</a>
        </div>
      </article>

      <p class="self-host-note">
        Prefer to run your own infrastructure?
        <a href="/docs/guides/self-hosting/">Self-hosting is free forever</a> — deploy your own instance at no cost.
      </p>
    </div>
  </section>

  <!-- ── Compare ────────────────────────────────────── -->
  <section class="section compare">
    <div class="container">
      <p class="section-eyebrow">Compare options</p>
      <h2>Managed or self-hosted — your choice</h2>
      <p class="section-sub">
        Unlike Disqus, we never monetise your readers' data through advertising.
        Comments belong to you and can be exported at any time on any paid plan.
      </p>
      <div class="table">
        <table>
          <thead>
            <tr>
              <th></th>
              <th>Hosted — Free</th>
              <th>Hosted — Paid</th>
              <th>Self-Hosted</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Cost</td>
              <td>Free</td>
              <td>From $9 / month</td>
              <td>Free</td>
            </tr>
            <tr>
              <td>Setup time</td>
              <td>Under 5 min</td>
              <td>Under 5 min</td>
              <td>30 – 60 min</td>
            </tr>
            <tr>
              <td>Requires own server</td>
              <td><span class="badge success">No</span></td>
              <td><span class="badge success">No</span></td>
              <td><span class="badge warning">Yes</span></td>
            </tr>
            <tr>
              <td>Database management</td>
              <td>Managed</td>
              <td>Managed</td>
              <td>Your responsibility</td>
            </tr>
            <tr>
              <td>Automatic updates</td>
              <td><span class="badge success">Yes</span></td>
              <td><span class="badge success">Yes</span></td>
              <td>Manual</td>
            </tr>
            <tr>
              <td>Backups</td>
              <td>Included</td>
              <td>Included</td>
              <td>Your responsibility</td>
            </tr>
            <tr>
              <td>Data ownership</td>
              <td><span class="badge success">Full</span></td>
              <td><span class="badge success">Full</span></td>
              <td><span class="badge success">Full</span></td>
            </tr>
            <tr>
              <td>Support</td>
              <td>Community</td>
              <td>Email / Dedicated</td>
              <td>Community</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ── CTA ───────────────────────────────────────── -->
  <section class="section cta-section">
    <div class="container">
      <div class="cta-inner">
        <h2>Ready to take back your comments?</h2>
        <p>Up and running in minutes — no server setup, zero maintenance. Or self-host for free on your own infrastructure.<br />No ads. No lock-in. Your data, always.</p>
        <div class="cta-actions">
          <a href={signupUrl} class="button large">Get started free</a>
          <a href="/docs/" class="button outline large">Read the docs</a>
        </div>
      </div>
    </div>
  </section>

</Layout>
