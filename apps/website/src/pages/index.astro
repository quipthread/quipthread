---
import '@knadh/oat/oat.min.css'
const backendUrl = import.meta.env.PUBLIC_BACKEND_URL || 'http://localhost:8080'
const loginUrl = `${backendUrl}/login`
const signupUrl = `${backendUrl}/signup`
const year = new Date().getFullYear()
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Quipthread — The comment system your readers will actually use</title>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <meta name="description" content="The comment platform your readers will actually use. Up and running in minutes — no server required. Free plan available. Open core and self-hostable." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,700;12..96,800&family=Syne:wght@700;800&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet" />
  <!-- Prevent flash of wrong theme -->
  <script is:inline>
    (function () {
      var s = localStorage.getItem('qt-theme');
      var dark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      if (s === 'light' || (!s && !dark)) {
        document.documentElement.setAttribute('data-theme', 'light');
      }
    })();
  </script>
</head>
<body>

  <!-- Grain texture overlay -->
  <div class="grain" aria-hidden="true"></div>

  <nav>
    <a href="/" class="wordmark">Quipthread</a>
    <div class="nav-links">
      <a href="#pricing">Pricing</a>
      <a href="/docs/">Docs</a>
      <a href="https://github.com/quipthread/quipthread" target="_blank" rel="noopener noreferrer">GitHub</a>
    </div>
    <a href={loginUrl} class="button ghost nav-login">Log in</a>
    <button class="theme-toggle" id="theme-toggle" aria-label="Toggle light/dark mode">
      <!-- Shown in dark mode; clicking switches to light -->
      <svg class="icon-sun" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="5"/>
        <line x1="12" y1="1" x2="12" y2="3"/>
        <line x1="12" y1="21" x2="12" y2="23"/>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
        <line x1="1" y1="12" x2="3" y2="12"/>
        <line x1="21" y1="12" x2="23" y2="12"/>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
      </svg>
      <!-- Shown in light mode; clicking switches to dark -->
      <svg class="icon-moon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
    </button>
    <button class="menu-toggle" id="menu-toggle" data-variant="icon" aria-label="Toggle menu" aria-expanded="false">
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
    </button>
    <!-- Mobile nav drawer (absolutely positioned below sticky nav) -->
    <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
      <a href="#pricing">Pricing</a>
      <a href="/docs/">Docs</a>
      <a href="https://github.com/quipthread/quipthread" target="_blank" rel="noopener noreferrer">GitHub</a>
      <div class="mobile-menu-footer">
        <a href={loginUrl} class="button outline mobile-login">Log in</a>
        <button class="theme-toggle" id="menu-theme-toggle" aria-label="Toggle light/dark mode">
          <svg class="icon-sun" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="5"/>
            <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
          <svg class="icon-moon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </button>
      </div>
    </div>
  </nav>

  <!-- ── Hero ─────────────────────────────────────── -->
  <section class="hero">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="container">
      <div class="hero-content">
        <div class="hero-text">
          <p class="hero-eyebrow">
            <span class="badge outline">Open core</span>
            <span class="badge outline">Managed platform</span>
          </p>
          <h1>The comment system your readers will <em>actually use.</em></h1>
          <p class="subhead">
            Start accepting comments in minutes — no server setup, zero maintenance.
            No ads. No tracking. Your data, always exportable.
          </p>
          <div class="hero-actions">
            <a href={signupUrl} class="button large">Start for free</a>
            <a href="/docs/" class="button outline large">Read the docs</a>
          </div>
        </div>
        <div class="hero-visual">
          <div class="hw-shell">
            <div class="hw-chrome">
              <span class="dot"></span><span class="dot"></span><span class="dot"></span>
              <span class="hw-label">quipthread</span>
            </div>
            <div class="hw-root">
              <div class="hw-header">
                <h2 class="hw-title">3 Comments</h2>
                <div class="hw-user-bar">
                  <span class="hw-av hw-av-lg hw-av-you">SK</span>
                  <span class="hw-user-name">Sarah K.</span>
                  <button class="hw-btn-ghost">Sign out</button>
                </div>
              </div>
              <ul class="hw-comment-list">
                <li class="hw-comment">
                  <span class="hw-av hw-av-lg hw-av-blue">AM</span>
                  <div class="hw-comment-body">
                    <div class="hw-comment-meta">
                      <span class="hw-author">Alex M.</span>
                      <span class="hw-ts">2 hours ago</span>
                    </div>
                    <div class="hw-content">The new dark mode looks fantastic. Really appreciate the attention to detail on the color transitions.</div>
                    <div class="hw-actions">
                      <button class="hw-btn-ghost hw-action-btn">Reply</button>
                    </div>
                    <div class="hw-replies">
                      <div class="hw-reply">
                        <span class="hw-av hw-av-sm hw-av-you">SK</span>
                        <div class="hw-comment-body">
                          <div class="hw-comment-meta">
                            <span class="hw-author">Sarah K.</span>
                            <span class="hw-ts">1 hour ago</span>
                          </div>
                          <div class="hw-content">Thanks! Getting the contrast ratio right was the tricky part.</div>
                        </div>
                      </div>
                    </div>
                  </div>
                </li>
                <li class="hw-comment">
                  <span class="hw-av hw-av-lg hw-av-green">JP</span>
                  <div class="hw-comment-body">
                    <div class="hw-comment-meta">
                      <span class="hw-author">Jordan P.</span>
                      <span class="hw-ts">yesterday</span>
                    </div>
                    <div class="hw-content">Switched from Disqus last week. Import worked flawlessly — readers haven't noticed a thing.</div>
                    <div class="hw-actions">
                      <button class="hw-btn-ghost hw-action-btn">Reply</button>
                    </div>
                  </div>
                </li>
              </ul>
              <div class="hw-new-comment">
                <div class="hw-new-header">
                  <span class="hw-new-label">Leave a comment</span>
                </div>
                <div class="hw-editor-wrapper">
                  <div class="hw-toolbar">
                    <button class="hw-tb-btn"><strong>B</strong></button>
                    <button class="hw-tb-btn"><em>I</em></button>
                    <button class="hw-tb-btn"><s>S</s></button>
                    <div class="hw-tb-sep"></div>
                    <button class="hw-tb-btn">≡</button>
                    <button class="hw-tb-btn">№</button>
                    <div class="hw-tb-sep"></div>
                    <button class="hw-tb-btn">&lt;&gt;</button>
                    <button class="hw-tb-btn">↗</button>
                  </div>
                  <div class="hw-editor-content">
                    <p class="hw-placeholder">What are your thoughts?</p>
                  </div>
                </div>
                <div class="hw-form-actions">
                  <button class="hw-btn-primary">Comment</button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Features ──────────────────────────────────── -->
  <section class="section features">
    <div class="container">
      <p class="section-eyebrow">Why Quipthread</p>
      <div class="row">
        <div class="col-3">
          <article class="card feature-card">
            <div class="feature-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
              </svg>
            </div>
            <h3>Open Core</h3>
            <p>The comment engine, embed widget, and admin dashboard are fully open source (AGPL). Inspect the code, fork it, self-host it. No vendor lock-in.</p>
          </article>
        </div>
        <div class="col-3">
          <article class="card feature-card">
            <div class="feature-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
            </div>
            <h3>Your Data</h3>
            <p>No ad targeting. No data brokering. Comments belong to you — export everything as JSON or CSV at any time.</p>
          </article>
        </div>
        <div class="col-3">
          <article class="card feature-card">
            <div class="feature-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
              </svg>
            </div>
            <h3>Rich Comments</h3>
            <p>Markdown, threading, GitHub/Google/email auth, and email notifications. Everything readers need, nothing they don't.</p>
          </article>
        </div>
        <div class="col-3">
          <article class="card feature-card">
            <div class="feature-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 4a1 1 0 0 1 1-1h16a1 1 0 0 1 .78 1.63L14 12.41V19a1 1 0 0 1-.55.89l-4 2A1 1 0 0 1 8 21v-8.59L3.22 5.63A1 1 0 0 1 3 5V4z"/>
              </svg>
            </div>
            <h3>Spam Protection</h3>
            <p>Rate limiting, heuristic content analysis, Cloudflare Turnstile support, and a keyword blocklist keep your comments clean without moderator effort.</p>
          </article>
        </div>
      </div>
    </div>
  </section>

  <!-- ── How It Works ──────────────────────────────── -->
  <section class="section how-it-works">
    <div class="container">
      <p class="section-eyebrow">How it works</p>
      <h2>Up and running in three steps</h2>
      <div class="steps">
        <div class="step">
          <div class="step-num">1</div>
          <div class="step-body">
            <h4>Sign up and get your Site ID</h4>
            <p>Create an account and get a Site ID in under two minutes — no server required. Prefer to run your own infrastructure? Self-hosters deploy the Go binary with SQLite included.</p>
          </div>
        </div>
        <div class="step-connector"></div>
        <div class="step">
          <div class="step-num">2</div>
          <div class="step-body">
            <h4>Drop in the script tag</h4>
            <p>Paste one line into your site wherever you want comments. Loads asynchronously — zero layout shift, works with any framework or static site generator.</p>
          </div>
        </div>
        <div class="step-connector"></div>
        <div class="step">
          <div class="step-num">3</div>
          <div class="step-body">
            <h4>Moderate from your dashboard</h4>
            <p>Readers comment; you approve or reject from the admin dashboard. Pending comments notify you by email with a one-click approve link.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Pricing ────────────────────────────────────── -->
  <section class="section pricing" id="pricing">
    <div class="container">
      <p class="section-eyebrow">Pricing</p>
      <h2>Simple, transparent pricing</h2>
      <p class="section-sub">
        Self-host for free, forever. Or skip the ops work and use the managed platform.
        14-day free trial on Pro — no credit card required.
      </p>

      <ot-tabs class="pricing-tabs">
        <div role="tablist">
          <button role="tab">Monthly</button>
          <button role="tab">Annual <span class="badge success tab-badge">Save ~17%</span></button>
        </div>

