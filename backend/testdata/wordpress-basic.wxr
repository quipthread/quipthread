      <!-- Approved reply to comment 1 -->
      <wp:comment>
        <wp:comment_id>3</wp:comment_id>
        <wp:comment_author>Alice Smith</wp:comment_author>
        <wp:comment_author_email>alice@example.com</wp:comment_author_email>
