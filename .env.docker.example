# ── Required ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
BASE_URL=https://comments.example.com

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of origins that may embed the comment widget.
ALLOWED_ORIGINS=https://comments.example.com

# ── Litestream replication (optional — strongly recommended) ──────────────────
# Point at any S3-compatible bucket (AWS S3, Cloudflare R2, MinIO).
# Leave blank to run without replication.
LITESTREAM_REPLICA_URL=
LITESTREAM_ACCESS_KEY_ID=
LITESTREAM_SECRET_ACCESS_KEY=

# ── OAuth providers ───────────────────────────────────────────────────────────
# Enable by providing both keys for a provider. At least one provider required.
# Redirect URI to register: <BASE_URL>/auth/<provider>/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email / password auth (disabled by default) ───────────────────────────────
EMAIL_AUTH_ENABLED=false

# SMTP — used for verification emails and password reset.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# Transactional email API — overrides SMTP when set.
# Accepted values: resend, postmark, sendgrid
EMAIL_PROVIDER=
EMAIL_API_KEY=

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_COMMENTS=5/10m
RATE_LIMIT_AUTH=10/5m

# ── Spam filtering ────────────────────────────────────────────────────────────
SPAM_MAX_LINKS=3

# ── Bot protection (optional) ─────────────────────────────────────────────────
# Cloudflare Turnstile — omit both to disable.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Notifications ─────────────────────────────────────────────────────────────
NOTIFY_BATCH_SIZE=5
NOTIFY_COOLDOWN_HOURS=24
# Fallback recipient if the site owner has no email on file.
NOTIFY_EMAIL_TO=

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

SLACK_WEBHOOK_URL=

DISCORD_WEBHOOK_URL=

WEBHOOK_URL=

# ── Turso / libSQL (optional) ─────────────────────────────────────────────────
# Use a Turso database instead of the local SQLite file.
# Set DATABASE_URL in docker-compose.yml or here, then provide the auth token.
# DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=
